# Claude Code per-project session/auth state. Do not commit — contains
# machine-specific allowlist of bash/powershell commands.
.claude/

# Generated by package-effects.py — regenerate locally rather than tracking.
effects/*/*.zip
effects/*/source-bundle.js

# Raw source media kept locally for re-encoding / re-cropping. Each effect
# only ships the final assets/; the source-media/ folder (raw mp4/jpg
# pulled from the original site) can be 100+ MB and doesn't belong in git.
effects/*/source-media/

# Generated by scrape-url.py headless verify — re-generated on each scrape.
designs/*/preview.png

# Python bytecode cache.
__pycache__/
*.pyc
OPEN.command

# Local-only mirrors that opt out of the shared gallery via a `.skip-index`
# sentinel inside the folder. rebuild-index.py also reads `.skip-index` and
# omits these from designs.json / effects.json. Used when a remote teammate
# already pushed a better version of the same site (e.g. our local
# designs/014-floema is superseded by designs/Floema in 5f12f62).
designs/014-floema/
.skip-index
