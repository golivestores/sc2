82,"_type":67,"children":183,"markDefs":188,"style":97},"46cb2d6046d6",[184],{"_key":185,"_type":71,"marks":186,"text":187},"deb4afdc7cb5",[],"XS2, S and M models communicate information about biodiversity and built and natural heritage. XL totems, placed at the entrances of Bussaco National Forest, function as boundary and information points, displaying maps, regulations and access information.",[],{"_key":190,"_type":67,"children":191,"markDefs":196,"style":97},"540b53389b11",[192],{"_key":193,"_type":71,"marks":194,"text":195},"06cbcd9da199",[],"The structures are produced in metallised steel with textured polyurethane coating. Information panels are integrated HPL+ plates, CNC/laser engraved and finished with two-component polyurethane paint.",[],{"_key":198,"_type":67,"children":199,"markDefs":203,"style":97},"216ad6c3b92e",[200],{"_key":201,"_type":71,"marks":202,"text":95},"8331911df4a1",[],[],{"_key":205,"_type":67,"children":206,"markDefs":211,"style":159},"c85bafdbcfa0",[207],{"_key":208,"_type":71,"marks":209,"text":210},"bcc7aa4f0ced",[],"SMART signage",[],{"_key":213,"_type":124,"mediaAsset":214},"94946833cb9c",[215],{"alt":8,"extension":11,"height":216,"hotspot":8,"type":13,"uid":217,"url":218,"width":219},2870,"64aa4eaac1b1","https://cdn.sanity.io/images/535lnz3g/production/4564093151420f4e96bcee7e212fc6c537ca9473-4304x2870.jpg",4304,{"_key":221,"_type":67,"children":222,"markDefs":227,"style":97},"7ce8f956b2a8",[223],{"_key":224,"_type":71,"marks":225,"text":226},"e1f3d0c185f4",[],"To extend the visitor experience, QR codes were integrated into the totems, providing direct access to a digital platform with additional content.",[],{"_key":229,"_type":67,"children":230,"markDefs":235,"style":97},"895a5581fb4a",[231],{"_key":232,"_type":71,"marks":233,"text":234},"2e5366ca7e2e",[],"This digital layer complements physical interpretation and introduces a continuous and intelligent communication system.",[],{"_key":237,"_type":67,"children":238,"markDefs":242,"style":97},"6d10205c28b1",[239],{"_key":240,"_type":71,"marks":241,"text":95},"2ee1992b087b",[],[],{"_key":244,"_type":67,"children":245,"markDefs":250,"style":159},"6f3b24533436",[246],{"_key":247,"_type":71,"marks":248,"text":249},"6bda0fbc806c",[],"Frame directional signage",[],{"_key":252,"_type":124,"mediaAsset":253},"7a7777de3625",[254],{"alt":8,"extension":11,"height":255,"hotspot":8,"type":13,"uid":256,"url":257,"width":258},1435,"0a677abfe675","https://cdn.sanity.io/images/535lnz3g/production/7342aec3faf7d4fbbc931c6ec014741818396a49-2152x1435.jpg",2152,{"_key":260,"_type":67,"children":261,"markDefs":266,"style":97},"93e3017608e1",[262],{"_key":263,"_type":71,"marks":264,"text":265},"7f3ad5a9b5c0",[],"Directional Frame signs ensure route guidance throughout the park. As with the totems, all information is CNC/laser engraved and finished with two-component polyurethane paint.",[],{"_key":268,"_type":67,"children":269,"markDefs":274,"style":97},"25c5ab602e0f",[270],{"_key":271,"_type":71,"marks":272,"text":273},"29c8ce5e6008",[],"Signs are mounted on metallised and painted steel posts, with fixing systems designed to simplify installation and graphic replacement.",[],{"_key":276,"_type":67,"children":277,"markDefs":281,"style":97},"33b6b8417515",[278],{"_key":279,"_type":71,"marks":280,"text":95},"b4318cbf5ff7",[],[],{"_key":283,"_type":67,"children":284,"markDefs":289,"style":159},"23d0585dfc2f",[285],{"_key":286,"_type":71,"marks":287,"text":288},"8bc5f98f7c49",[],"Custom markers",[],{"_key":291,"_type":124,"mediaAsset":292},"da8189ad4576",[293],{"alt":8,"extension":11,"height":255,"hotspot":8,"type":13,"uid":294,"url":295,"width":258},"f312dac798eb","https://cdn.sanity.io/images/535lnz3g/production/f76a711d0ac39a0d4fc5cc2b8450c005415f35e8-2152x1435.jpg",{"_key":297,"_type":67,"children":298,"markDefs":303,"style":97},"331a3894d24d",[299],{"_key":300,"_type":71,"marks":301,"text":302},"67427acf833b",[],"The park offers two distinct routes — the Water Trail and the Via Sacra Trail — that cross the forest and allow visitors to explore both natural and historical heritage.",[],{"_key":305,"_type":67,"children":306,"markDefs":311,"style":97},"adbc9d89b124",[307],{"_key":308,"_type":71,"marks":309,"text":310},"7278827ea55c",[],"Custom markers were developed in brown recycled plastic, ensuring orientation while maintaining discreet integration into the landscape.",[],{"_key":313,"_type":67,"children":314,"markDefs":318,"style":97},"8982cc1812d1",[315],{"_key":316,"_type":71,"marks":317,"text":95},"3a1fa7b5236a",[],[],{"_key":320,"_type":67,"children":321,"markDefs":326,"style":159},"d1012fde7f5c",[322],{"_key":323,"_type":71,"marks":324,"text":325},"2adb46ccb3d4",[],"Floema Nature information signs",[],{"_key":328,"_type":124,"mediaAsset":329},"9205d6857a39",[330],{"alt":8,"extension":11,"height":255,"hotspot":8,"type":13,"uid":331,"url":332,"width":258},"c804ac62439d","https://cdn.sanity.io/images/535lnz3g/production/fa986ab6641e2c179f74234f256e5268642f1e86-2152x1435.jpg",{"_key":334,"_type":67,"children":335,"markDefs":340,"style":97},"682ea69dd992",[336],{"_key":337,"_type":71,"marks":338,"text":339},"8c89d3a1bb6a",[],"Communicating rules for the use and protection of ecosystems is essential for preserving the space and ensuring a quality experience for visitors.",[],{"_key":342,"_type":67,"children":343,"markDefs":348,"style":97},"2af3db644963",[344],{"_key":345,"_type":71,"marks":346,"text":347},"652f948cc841",[],"Floema Nature information signs were produced and installed, made of HPL+ with recycled plastic posts — highly durable supports that are resistant to exposure and maintenance-free.",[],{"_key":350,"_type":67,"children":351,"markDefs":355,"style":97},"a06da9cbd76e",[352],{"_key":353,"_type":71,"marks":354,"text":95},"9c2eeb97af74",[],[],{"_key":357,"_type":67,"children":358,"markDefs":363,"style":121},"441b5d88e281",[359],{"_key":360,"_type":71,"marks":361,"text":362},"120047450df8",[],"Furniture",[],{"_k