co-national-forest","Bussaco National Forest - signage, furniture and structures Floema",[49,62],{"_type":50,"category":51,"date":8,"figure":54,"readTime":61,"title":39},"articleHeader",{"name":52,"slug":53},"Case Studies","case-studies",{"author":55,"caption":56,"mediaAsset":57},"Floema","Entrada",[58],{"alt":59,"extension":11,"height":12,"hotspot":8,"type":13,"uid":60,"url":15,"width":16},"Bussaco National Forest Floema","a3fee4db9250",4,{"_type":63,"content":64,"readingTime":61,"type":4},"articleContent",[65,89,98,106,113,122,128,136,144,151,160,166,173,181,189,197,204,212,220,228,236,243,251,259,267,275,282,290,296,304,312,319,327,333,341,349,356,364,370,378,386,393],{"_key":66,"_type":67,"children":68,"markDefs":83,"style":88},"ac270720eb7b","block",[69,74,79],{"_key":70,"_type":71,"marks":72,"text":73},"c91dbb5b5d1f","span",[],"The ",{"_key":75,"_type":71,"marks":76,"text":78},"8f017603e75f",[77],"7d6cff845cb4","Bussaco Forest Foundation",{"_key":80,"_type":71,"marks":81,"text":82},"8307a5b1ed85",[]," invited Floema to design, produce and install equipment and communication supports integrated into this National Monument — a territory of remarkable biodiversity and historical heritage.",[84],{"_key":77,"_type":85,"href":86,"linkType":87,"to":8},"link","http://www.fmb.pt/v2/pt/","external","h4",{"_key":90,"_type":67,"children":91,"markDefs":96,"style":97},"da02e897ab3e",[92],{"_key":93,"_type":71,"marks":94,"text":95},"dc4f0a87da01",[],"",[],"normal",{"_key":99,"_type":67,"children":100,"markDefs":105,"style":97},"a41c8ed696cb",[101],{"_key":102,"_type":71,"marks":103,"text":104},"9076dbcac001",[],"The intervention focused on creating systems of orientation, interpretation and permanence capable of dialoguing with the landscape while ensuring durability, safety and continuity over time.",[],{"_key":107,"_type":67,"children":108,"markDefs":112,"style":97},"7eec7f42f727",[109],{"_key":110,"_type":71,"marks":111,"text":95},"62c31f0711b0",[],[],{"_key":114,"_type":